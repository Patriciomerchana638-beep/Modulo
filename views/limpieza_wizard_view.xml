<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- ══════════════════════════════════════════════
         WIZARD 1 — INICIO DE LIMPIEZA
    ══════════════════════════════════════════════ -->
    <record id="view_limpieza_inicio_wizard_form" model="ir.ui.view">
      <field name="name">bordado.limpieza.inicio.wizard.form</field>
      <field name="model">bordado.limpieza.inicio.wizard</field>
      <field name="arch" type="xml">
        <form string="Iniciar Limpieza">
          <sheet>

            <field name="limpieza_id" invisible="1"/>

            <!-- Encabezado visual táctil -->
            <div class="alert alert-warning text-center mb-4" role="alert">
              <h3 class="mb-1">🔧 Iniciando Limpieza</h3>
              <h2 class="fw-bold mb-0">
                <field name="maquina_nombre" readonly="1"/>
              </h2>
            </div>

            <!-- Selección de operarios con checkboxes (fácil en pantalla táctil) -->
            <group>
              <div class="mb-2">
                <b style="font-size: 18px;">Selecciona los operarios en turno:</b>
              </div>
              <field name="operario_ids"
                     widget="many2many_checkboxes"
                     nolabel="1"
                     style="font-size: 18px; line-height: 2.2;"/>
            </group>

          </sheet>
          <footer>
            <button string="🚀 CONFIRMAR INICIO"
                    name="action_confirmar_inicio"
                    type="object"
                    class="btn-warning btn-lg"
                    style="font-size: 20px; height: 64px; min-width: 220px;"/>
            <button string="Cancelar" special="cancel" class="btn-secondary"/>
          </footer>
        </form>
      </field>
    </record>

    <!-- ══════════════════════════════════════════════
         WIZARD 2 — FIN DE LIMPIEZA
    ══════════════════════════════════════════════ -->
    <record id="view_limpieza_fin_wizard_form" model="ir.ui.view">
      <field name="name">bordado.limpieza.fin.wizard.form</field>
      <field name="model">bordado.limpieza.fin.wizard</field>
      <field name="arch" type="xml">
        <form string="Finalizar Limpieza">
          <sheet>

            <field name="limpieza_id" invisible="1"/>

            <!-- Encabezado visual táctil -->
            <div class="alert alert-success text-center mb-4" role="alert">
              <h3 class="mb-1">✅ Finalizando Limpieza</h3>
              <h2 class="fw-bold mb-1">
                <field name="maquina_nombre" readonly="1"/>
              </h2>
              <p class="mb-0 text-muted">
                Inicio: <strong><field name="inicio_info" readonly="1"/></strong>
              </p>
            </div>

            <!-- Campo de observaciones requerido -->
            <group>
              <div class="mb-2">
                <b style="font-size: 18px;">Observaciones de la limpieza:</b>
              </div>
              <field name="observaciones"
                     nolabel="1"
                     placeholder="Ej: Sistema de engranajes lubricado. Guías limpias. Sin anomalías."
                     style="min-height: 130px; font-size: 16px; width: 100%;"/>
            </group>

          </sheet>
          <footer>
            <button string="✅ CONFIRMAR FIN"
                    name="action_confirmar_fin"
                    type="object"
                    class="btn-success btn-lg"
                    style="font-size: 20px; height: 64px; min-width: 220px;"/>
            <button string="Cancelar" special="cancel" class="btn-secondary"/>
          </footer>
        </form>
      </field>
    </record>

  </data>
</odoo>
