<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <record id="view_bordado_limpieza_search" model="ir.ui.view">
      <field name="name">bordado.limpieza.search</field>
      <field name="model">bordado.limpieza</field>
      <field name="arch" type="xml">
        <search string="Buscar Limpieza">
          <field name="maquina_id" string="Maquina"/>
          <filter name="pendiente"  string="Pendiente"  domain="[('state', '=', 'pendiente')]"/>
          <filter name="en_proceso" string="En Proceso" domain="[('state', '=', 'en_proceso')]"/>
          <filter name="finalizado" string="Finalizado" domain="[('state', '=', 'finalizado')]"/>
        </search>
      </field>
    </record>

    <record id="view_bordado_limpieza_kanban" model="ir.ui.view">
      <field name="name">bordado.limpieza.kanban</field>
      <field name="model">bordado.limpieza</field>
      <field name="arch" type="xml">
        <kanban default_group_by="state" records_draggable="false">
          <field name="state"/>
          <field name="maquina_id"/>
          <field name="operario_ids"/>
          <field name="inicio"/>
          <field name="duracion"/>
          <field name="fecha"/>
          <templates>
            <t t-name="card">

              <!-- Franja de color lateral según estado -->
              <div t-att-class="{
                    'border-start border-4 border-secondary': record.state.raw_value === 'pendiente',
                    'border-start border-4 border-warning':   record.state.raw_value === 'en_proceso',
                    'border-start border-4 border-success':   record.state.raw_value === 'finalizado'
                  }"
                   style="min-height: 180px; padding: 14px;">

                <!-- ENCABEZADO: Nombre de Máquina -->
                <div class="mb-2 d-flex align-items-center justify-content-between">
                  <strong style="font-size: 19px;">
                    <i class="fa fa-cog me-1"/>
                    <field name="maquina_id"/>
                  </strong>
                  <small class="text-muted"><field name="fecha"/></small>
                </div>

                <!-- BADGE DE ESTADO -->
                <div class="mb-3">
                  <field name="state" widget="badge"
                    decoration-secondary="state == 'pendiente'"
                    decoration-warning="state == 'en_proceso'"
                    decoration-success="state == 'finalizado'"/>
                </div>

                <!-- OPERARIOS — visible solo cuando está en proceso -->
                <div t-if="record.state.raw_value === 'en_proceso'" class="mb-3">
                  <div class="fw-bold text-muted mb-1" style="font-size: 12px; text-transform: uppercase;">
                    👷 Operarios
                  </div>
                  <field name="operario_ids" widget="many2many_tags"/>
                </div>

                <!-- RESULTADO — visible solo cuando finalizado -->
                <div t-if="record.state.raw_value === 'finalizado'" class="mb-3 text-success">
                  <i class="fa fa-check-circle me-1"/>
                  Duración: <strong><field name="duracion"/> min</strong>
                </div>

                <!-- BOTONES TÁCTILES -->
                <div class="mt-2">
                  <button t-if="record.state.raw_value === 'pendiente'"
                          name="action_abrir_wizard_inicio"
                          type="object"
                          class="btn btn-warning w-100 fw-bold"
                          style="height: 64px; font-size: 19px; border-radius: 10px;">
                     INICIAR
                  </button>
                  <button t-if="record.state.raw_value === 'en_proceso'"
                          name="action_abrir_wizard_fin"
                          type="object"
                          class="btn btn-success w-100 fw-bold"
                          style="height: 64px; font-size: 19px; border-radius: 10px;">
                     FINALIZAR
                  </button>
                  <div t-if="record.state.raw_value === 'finalizado'"
                       class="text-center text-success fw-bold py-2"
                       style="font-size: 16px;">
                    ✔ Limpieza Completada
                  </div>
                </div>

              </div>
            </t>
          </templates>
        </kanban>
      </field>
    </record>

   
    <record id="view_bordado_limpieza_form" model="ir.ui.view">
      <field name="name">bordado.limpieza.form</field>
      <field name="model">bordado.limpieza</field>
      <field name="arch" type="xml">
        <form>
          <header>
            <field name="state" widget="statusbar"
                   statusbar_visible="pendiente,en_proceso,finalizado"/>
          </header>
          <sheet>
            <group>
              <group string="Datos de la Tarea">
                <field name="maquina_id"/>
                <field name="fecha"/>
                <field name="operario_ids" widget="many2many_tags"/>
              </group>
              <group string="Tiempos">
                <field name="inicio" readonly="1"/>
                <field name="fin" readonly="1"/>
                <field name="duracion" readonly="1"/>
              </group>
            </group>
            <group string="Observaciones">
              <field name="observaciones" nolabel="1"
                     placeholder="Detalles de la limpieza realizada..."/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    
    <record id="view_bordado_limpieza_list" model="ir.ui.view">
      <field name="name">bordado.limpieza.list</field>
      <field name="model">bordado.limpieza</field>
      <field name="arch" type="xml">
        <list decoration-warning="state == 'en_proceso'"
              decoration-success="state == 'finalizado'"
              decoration-muted="state == 'pendiente'">
          <field name="fecha"/>
          <field name="maquina_id"/>
          <field name="inicio"/>
          <field name="fin"/>
          <field name="duracion" sum="Total min"/>
          <field name="state"/>
        </list>
      </field>
    </record>

   
    <record id="action_bordado_limpieza" model="ir.actions.act_window">
      <field name="name"> Dashboard de Limpieza</field>
      <field name="res_model">bordado.limpieza</field>
      <field name="view_mode">kanban,list,form</field>
      <field name="domain">[]</field>
    </record>

    
    <menuitem id="menu_limpieza"
              name="Limpieza de Máquinas"
              parent="menu_bordado_root"
              action="action_bordado_limpieza"
              sequence="15"
              groups="base.group_erp_manager"/>

  </data>
</odoo>
