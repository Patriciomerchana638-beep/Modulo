<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bordado_falla_wizard_form" model="ir.ui.view">
        <field name="name">bordado.falla.wizard.form</field>
        <field name="model">bordado.falla.wizard</field>
        <field name="arch" type="xml">
            <form string="Reportar Falla">
                <group>
                    <field name="orden_id" invisible="1"/>
                    <field name="hora_inicio_falla" invisible="1"/>
                    <field name="tipo" widget="radio"/>
                    <field name="nota" placeholder="Describe el problema..."/>
                </group>
                <footer>
                    <button string="Registrar Falla" name="action_confirmar_falla" type="object" class="btn-danger"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>