<odoo>
  <data>
    <record id="view_bordado_orden_form" model="ir.ui.view">
        <field name="name">bordado.orden.form</field>
        <field name="model">bordado.orden</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_preparar" string="⏱️ Buscar Materiales (15min)" type="object" class="btn-primary" invisible="state != 'borrador'"/>
                    <button name="action_bordar" string="🧵 Iniciar Máquina" type="object" class="btn-success" invisible="state != 'preparacion'"/>
                    <button name="action_finalizar" string="✅ Terminar Pedido" type="object" class="btn-warning" invisible="state != 'produccion'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Datos">
                            <field name="cliente"/>
                            <field name="maquina_id"/>
                            <field name="operario_id" readonly="1"/>
                        </group>
                        <group string="Documento Digital">
                            <field name="nombre_archivo" invisible="1"/>
                            <field name="archivo_pdf" filename="nombre_archivo" widget="pdf_viewer"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_bordado_orden_kanban" model="ir.ui.view">
        <field name="name">bordado.orden.kanban</field>
        <field name="model">bordado.orden</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" records_draggable="false">
                <field name="name"/>
                <field name="cliente"/>
                <field name="state"/>
                <field name="maquina_id"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div>
                                    <span class="text-muted">Cliente: </span> <field name="cliente"/>
                                </div>
                                <div>
                                    <span class="text-muted">Máquina: </span> <field name="maquina_id"/>
                                </div>
                                <div class="mt-2">
                                    <field name="state" widget="label_selection" options="{'classes': {'borrador': 'default', 'preparacion': 'warning', 'produccion': 'success', 'finalizado': 'muted'}}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_bordado_orden_tree" model="ir.ui.view">
        <field name="name">bordado.orden.tree</field>
        <field name="model">bordado.orden</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="cliente"/>
                <field name="maquina_id"/>
                <field name="state" widget="badge" decoration-info="state == 'preparacion'" decoration-success="state == 'produccion'"/>
            </list>
        </field>
    </record>

    <record id="action_bordado_orden" model="ir.actions.act_window">
        <field name="name">Órdenes de Bordado</field>
        <field name="res_model">bordado.orden</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <menuitem id="menu_bordado_root" name="Fábrica Bordado" web_icon="mrp,static/description/icon.png"/>
    <menuitem id="menu_ordenes" name="Órdenes de Trabajo" parent="menu_bordado_root" action="action_bordado_orden" sequence="1"/>
  </data>
</odoo>