<odoo>
  <data>
    <record id="view_incidencia_form" model="ir.ui.view">
        <field name="name">bordado.incidencia.form</field>
        <field name="model">bordado.incidencia</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_resolver" string="Resuelto" type="object" invisible="state == 'resuelto'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="maquina_id"/>
                        <field name="tipo"/>
                        <field name="nota"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_incidencia" model="ir.actions.act_window">
        <field name="name">Reportar Falla</field>
        <field name="res_model">bordado.incidencia</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_incidencia" name="Reportar Falla" parent="menu_bordado_root" action="action_incidencia" sequence="99"/>
  </data>
</odoo>